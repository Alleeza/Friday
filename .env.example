# Copy this file to .env.local and fill in the providers you want to use.
# .env.local is git-ignored. Never commit your actual API keys.

# Supabase backend storage for project persistence and share links.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supported values: claude, ollama
# Leave this as `claude` unless you intentionally want to use local Ollama instead.
VITE_AI_PROVIDER=claude

# Claude / Anthropic
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here
VITE_CLAUDE_MODEL=claude-sonnet-4-20250514

# Ollama / local
# Make sure Ollama is running locally, for example:
#   ollama serve
#   ollama pull gemma3:12b
VITE_OLLAMA_MODEL=gemma3:12b
