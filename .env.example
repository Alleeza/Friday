# Copy this file to .env.local and fill in the provider you want to use.
# .env.local is git-ignored — never commit your actual API key.

# Supported values: claude, ollama
# Leave this as `claude` unless you intentionally want to use local Ollama instead.
VITE_AI_PROVIDER=claude

# Claude / Anthropic
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here
VITE_CLAUDE_MODEL=claude-haiku-4-5-20251001

# Ollama / local
# Make sure Ollama is running locally, for example:
#   ollama serve
#   ollama pull llama3.2
VITE_OLLAMA_MODEL=llama3.2
